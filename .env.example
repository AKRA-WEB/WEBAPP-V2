NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only. Do not expose this with NEXT_PUBLIC_ and do not commit real values.
SUPABASE_SECRET_KEY=your-secret-or-service-role-key

# Local migration/verification scripts only. Do not expose or commit real values.
DATABASE_URL=postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres

# Picking LINE notification (server-only). Starts disabled/dry-run per ADR 0018;
# real sends require LINE_CHANNEL_TOKEN/LINE_GROUP_ID plus explicit approval.
# Do not commit real values.
PICKING_LINE_PUSH_ENABLED=false
LINE_CHANNEL_TOKEN=your-line-channel-access-token
LINE_GROUP_ID=your-line-group-id
